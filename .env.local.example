# Google Apps Script deployment URL
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID/usercontent/exec

# Claude API Key (set in Google Apps Script, not here)
# This is stored in Code.gs

# Google Sheet ID (set in Code.gs)
# SHEET_ID=YOUR_SHEET_ID
NEXT_PUBLIC_GITHUB_TOKEN=your_github_personal_access_token_here
NEXT_PUBLIC_GITHUB_REPO=hjcodingwoo/manual-of-me
